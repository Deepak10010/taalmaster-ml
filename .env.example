# Copy this to .env and fill in your credentials.

# --- BigQuery (primary source for training data) ---
# Path to the service-account JSON key. Same key Airflow uses; just copy it
# from the data platform repo: data_platform/airflow/include/gcp-key.json
GOOGLE_APPLICATION_CREDENTIALS=../taalmaster/data_platform/airflow/include/gcp-key.json

# Defaults work for the dev environment; override for prod.
BQ_PROJECT=taalmaster-data-dev
BQ_RAW_DATASET=taalmaster_raw_dev
BQ_STAGING_DATASET=taalmaster_staging_dev
BQ_MARTS_DATASET=taalmaster_marts_dev

# --- Neon Postgres (prediction logging only — NOT for training data) ---
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/dbname?sslmode=require

# --- Cloudflare R2 (MLflow artifact store) ---
MLFLOW_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=<r2 access key id>
AWS_SECRET_ACCESS_KEY=<r2 secret access key>
AWS_DEFAULT_REGION=auto
